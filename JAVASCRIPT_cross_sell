// 2. POMOCNÁ FUNKCE PRO ZKRACOVÁNÍ TEXTU
function smartTruncate(str, n) {
    if (!str) return "";
    let cleanStr = str.replace("Kompletní specifikace", "")
                      .replace(new RegExp("[\\r\\n]+", "g"), " ")
                      .trim();
    if (cleanStr.length <= n) return cleanStr;
    const subString = cleanStr.substr(0, n - 1);
    let lastSpace = subString.lastIndexOf(" ");
    return (lastSpace > 0 ? subString.substr(0, lastSpace) : subString) + "...";
}

