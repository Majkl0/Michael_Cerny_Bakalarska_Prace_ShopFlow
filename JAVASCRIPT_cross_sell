// 5. LOGIKA VYHLEDÁVÁNÍ (Smart Match Fix)
let selected = (typeof selected_product !== 'undefined' && selected_product) ? selected_product.trim() : "";

function cleanName(str) {
    if (!str) return "";
    return str.replace(/\.\.\.$/, "").replace(/[.,\s]+$/, "").trim().toLowerCase();
}

let searchKey = cleanName(selected);
let fullProductName = "";
let upsellNames = [];

if (produktyDB[selected]) {
    fullProductName = selected;
} else {
    fullProductName = Object.keys(produktyDB).find(dbName => {
        let dbNameClean = dbName.toLowerCase();
        return searchKey.length > 5 && dbNameClean.includes(searchKey);
    });
}

if (fullProductName && produktyDB[fullProductName]) {
    upsellNames = produktyDB[fullProductName].upsell;
}

function findProduct(nameFragment) {
    if (!nameFragment || nameFragment.length < 3) return null;
    if (vsechnyProdukty[nameFragment]) return vsechnyProdukty[nameFragment];
    let key = Object.keys(vsechnyProdukty).find(k => k.toLowerCase().includes(nameFragment.toLowerCase()) || nameFragment.toLowerCase().includes(k.toLowerCase()));
    return key ? vsechnyProdukty[key] : null;
}

// 6. NAPLNĚNÍ CAROUSELU
let foundCount = 0;
let loopLimit = Math.min(10, upsellNames.length);

for (let i = 0; i < loopLimit; i++) {
    if (foundCount >= 6) break;
    let upsellNazev = upsellNames[i].trim();
    let produktData = findProduct(upsellNazev);

    if (produktData) {
        // Kontrola duplicity (pomocí URL)
        if (c1_url === produktData.link || c2_url === produktData.link || c3_url === produktData.link) continue;

        foundCount++;
        let finalImg = produktData.fotka && produktData.fotka.length > 10
            ? `https://wsrv.nl/?url=${encodeURIComponent(produktData.fotka)}&w=600&h=400&fit=cover`
            : "https://placehold.co/600x400?text=" + encodeURIComponent(upsellNazev.slice(0, 10));

        // NOVÝ FORMÁT POPISKU: 💰 Cena | Skladem | Zkrácený popis
        let shortPopis = smartTruncate(produktData.popis, 60);
        let finalDesc = `💰 ${produktData.cena} | Skladem | ${shortPopis}`;

        if (foundCount === 1) { c1_title = upsellNazev; c1_desc = finalDesc; c1_img = finalImg; c1_url = produktData.link; }
        if (foundCount === 2) { c2_title = upsellNazev; c2_desc = finalDesc; c2_img = finalImg; c2_url = produktData.link; }
        if (foundCount === 3) { c3_title = upsellNazev; c3_desc = finalDesc; c3_img = finalImg; c3_url = produktData.link; }
        if (foundCount === 4) { c4_title = upsellNazev; c4_desc = finalDesc; c4_img = finalImg; c4_url = produktData.link; }
        if (foundCount === 5) { c5_title = upsellNazev; c5_desc = finalDesc; c5_img = finalImg; c5_url = produktData.link; }
        if (foundCount === 6) { c6_title = upsellNazev; c6_desc = finalDesc; c6_img = finalImg; c6_url = produktData.link; }
    }
}

