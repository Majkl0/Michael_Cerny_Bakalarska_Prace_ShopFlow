        "69583bd63e867e0a0bc7eaa6": {
          "type": "code",
          "data": {
            "name": "",
            "code": "// ==========================================\n// 0. KONFIGURACE (THRESHOLD A TRIM)\n// ==========================================\nconst TITLE_TRIM_LENGTH = 47;\nconst DESC_TRIM_LENGTH = 65;\n// Minimální hodnocení od AI (číslo mezi 0.0 a 1.0)\nconst MIN_SCORE_THRESHOLD = 0.75; \n\n// ==========================================\n// 1. BEZPEČNÉ NAČTĚNÍ DAT Z PINECONE\n// ==========================================\nlet rawData = pinecone_raw;\nif (typeof rawData === 'string') {\n    try { rawData = JSON.parse(rawData); } catch (e) { rawData = {}; }\n}\n\n// Neprůstřelné hledání pole 'matches' v závislosti na formátu z Voiceflow\nlet matches = [];\nif (rawData && Array.isArray(rawData.matches)) {\n    matches = rawData.matches;\n} else if (rawData && rawData.response && Array.isArray(rawData.response.matches)) {\n    matches = rawData.response.matches;\n}\n\nlet validCards = [];\nlet usedIds = new Set();\n\n// --- POMOCNÉ FUNKCE ---\nfunction removeAccents(str) {\n    if (!str) return \"\";\n    return str.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").toLowerCase().trim();\n}\n\nfunction smartTruncate(str, n) {\n    if (!str) return \"\";\n    let cleanStr = str.replace(\"Kompletní specifikace\", \"\").replace(new RegExp(\"[\\\\r\\\\n]+\", \"g\"), \" \").trim();\n    return cleanStr.length <= n ? cleanStr : cleanStr.substring(0, n) + \"...\";\n}\n\n// ==========================================\n// 2. ANALÝZA DOTAZU (Zjištění záměru)\n// ==========================================\nconst USER_QUERY = (typeof last_utterance !== 'undefined') ? last_utterance.toLowerCase() : \"\";\nconst queryClean = removeAccents(USER_QUERY);\n\n// Klíčová slova pro detekci kategorií (přidáno slovo \"jaw\" pro rozpoznání motorek Jawa)\nconst MOTO_IDENTIFIERS = [\"motork\", \"motocykl\", \"stroj\", \"masin\", \"jaw\"];\nconst HELMET_WORDS = [\"helm\", \"prilb\", \"eso\", \"jet\", \"apex\", \"cooper\", \"oxygen\", \"cassida\", \"smk\"];\nconst MOTO_MODELS = [\"730\", \"350\", \"300\", \"42\", \"750\", \"634\", \"perak\", \"bobber\", \"geeny\", \"twin\"];\nconst NEWS_WORDS = [\"novink\", \"novy\", \"nove\", \"aktual\", \"predobjednavk\", \"rezervace\"];\nconst CLOTHING_WORDS = [\"tricko\", \"tric\", \"mikina\", \"bunda\", \"vest\", \"oblec\", \"kalhot\", \"rukavic\", \"ponozk\", \"cepic\"];\nconst DOPLNKY_WORDS = [\"brasn\", \"batoh\", \"kufr\", \"blatn\", \"zrcatk\", \"kryc\", \"doplnek\", \"doplnk\", \"prislusen\", \"olej\", \"retez\", \"zamek\", \"stojan\", \"gps\", \"interkom\", \"grip\", \"cisten\"];\n\n// Určení úmyslu uživatele\nconst isMotoSearch = MOTO_IDENTIFIERS.some(k => queryClean.includes(k));\nconst isHelmetSearch = HELMET_WORDS.some(k => queryClean.includes(k));\nconst wantsNews = NEWS_WORDS.some(k => queryClean.includes(k));\nconst isClothingSearch = CLOTHING_WORDS.some(k => queryClean.includes(k));\nconst isDoplnkySearch = DOPLNKY_WORDS.some(k => queryClean.includes(k));\nconst modelInQuery = MOTO_MODELS.find(m => queryClean.includes(m));\n\n// ==========================================\n// 3. CHYTRÁ SÉMANTICKÁ FILTRACE\n// ==========================================\nfor (let i = 0; i < matches.length; i++) {\n    const item = matches[i];\n    const m = item.metadata;\n    if (!m || usedIds.has(item.id)) continue;\n\n    const name = m.nazev || m.name || \"\";\n    const desc = m.popis || m.description || \"\";\n    const avail = m.dostupnost || m.availability || \"\";\n    const priceRaw = String(m.cena || m.price || \"\");\n    const category = removeAccents(m.kategorie || m.category || \"\");\n\n    const nameNorm = removeAccents(name);\n    const availNorm = removeAccents(avail);\n    const priceNorm = removeAccents(priceRaw);\n\n    let isPreorder = availNorm.includes(\"rezervace\") || priceNorm.includes(\"predobjednavka\");\n    let isNewProduct = isPreorder || nameNorm.includes(\"novink\") || removeAccents(desc).includes(\"novink\");\n\n    // Povolené podkategorie z nového CSV\n    const CLOTHING_CATEGORIES = [\"tricko\", \"mikina\", \"rukavice\", \"bunda\", \"kalhoty\", \"obleceni\"];\n    const ACCESSORY_CATEGORIES = [\"doplnky\", \"oleje\", \"cisteni\", \"kufr\", \"stojany\", \"brasny\"];\n\n    // --- KONTROLA ZÁMĚRU A KATEGORIE ---\n    let isAllowedCategory = false;\n\n    if (isMotoSearch && category === \"motorka\") isAllowedCategory = true;\n    if (isHelmetSearch && (category === \"helma\" || category === \"helmy\")) isAllowedCategory = true;\n    if (isClothingSearch && CLOTHING_CATEGORIES.includes(category)) isAllowedCategory = true;\n    if (isDoplnkySearch && ACCESSORY_CATEGORIES.includes(category)) isAllowedCategory = true;\n    if (modelInQuery && category === \"motorka\" && nameNorm.includes(modelInQuery)) isAllowedCategory = true;\n\n    // Pokud uživatel specifikoval, co chce (helmu, oblečení, atd.)\n    const hasSpecificIntent = isMotoSearch || isHelmetSearch || isClothingSearch || isDoplnkySearch || modelInQuery;\n    \n    if (hasSpecificIntent && !isAllowedCategory) {\n        // Uživatel specifikoval kategorii, ale tento produkt do ní nepatří -> vyhodit\n        continue; \n    }\n\n    // Novinky\n    if (wantsNews && !isNewProduct) continue;\n\n    // Skladovost\n    let isOutOfStock = availNorm.includes(\"vyprodano\") || (availNorm.includes(\"neni skladem\") && !availNorm.includes(\"dodavatel\"));\n    if (isOutOfStock && !isNewProduct) continue;\n\n    // --- ČISTÉ SÉMANTICKÉ SKÓRE ---\n    let totalScore = item.score; \n\n    // Aplikace thresholdu (zahodíme sémanticky irelevantní výsledky)\n    if (totalScore < MIN_SCORE_THRESHOLD) continue;\n\n    let priceNum = parseInt(priceNorm.replace(/[^0-9]/g, '')) || 0;\n    let cleanPrice = isPreorder ? \"Předobjednávka\" : (priceNum > 0 ? priceNum.toLocaleString() + \" Kč\" : \"Na dotaz\");\n    let finalTitle = name.length > (TITLE_TRIM_LENGTH + 3) ? name.substring(0, TITLE_TRIM_LENGTH) + \"...\" : name;\n\n    validCards.push({\n        title: name,\n        chatTitle: finalTitle,\n        chatDesc: `💰 ${cleanPrice} | ${isPreorder ? \"Rezervace\" : \"Skladem\"}\\n${smartTruncate(desc, DESC_TRIM_LENGTH)}`,\n        image: m.fotka || m.imageUrl || \"https://placehold.co/600x400?text=JAWA\",\n        url: m.link || m.url || \"#\",\n        score: totalScore\n    });\n    usedIds.add(item.id);\n}\n\n// ==========================================\n// 4. ŘAZENÍ A EXPORT\n// ==========================================\nvalidCards.sort((a, b) => b.score - a.score);\nvalidCards = validCards.slice(0, 5);\n\nfunction getFinal(index) {\n    if (validCards[index]) return validCards[index];\n    return { chatTitle: \"---\", chatDesc: \" \", image: \"https://placehold.co/1x1\", url: \"#\" };\n}\n\nconst c1 = getFinal(0); c1_title = c1.chatTitle; c1_desc = c1.chatDesc; c1_img = c1.image; c1_url = c1.url;\nconst c2 = getFinal(1); c2_title = c2.chatTitle; c2_desc = c2.chatDesc; c2_img = c2.image; c2_url = c2.url;\nconst c3 = getFinal(2); c3_title = c3.chatTitle; c3_desc = c3.chatDesc; c3_img = c3.image; c3_url = c3.url;\nconst c4 = getFinal(3); c4_title = c4.chatTitle; c4_desc = c4.chatDesc; c4_img = c4.image; c4_url = c4.url;\nconst c5 = getFinal(4); c5_title = c5.chatTitle; c5_desc = c5.chatDesc; c5_img = c5.image; c5_url = c5.url;\n\nvalid_count = validCards.length;",
